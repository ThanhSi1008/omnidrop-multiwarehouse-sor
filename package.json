{
  "name": "omnidrop-multiwarehouse-sor",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "dev:gateway": "npm run start:dev -w apps/api-gateway",
    "dev:core": "npm run start:dev -w apps/core-service",
    "dev:flash-sale": "npm run start:dev -w apps/flash-sale-service",
    "dev:order": "npm run start:dev -w apps/order-routing-service"
  }
}
