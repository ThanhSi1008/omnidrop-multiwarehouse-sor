{
  "name": "omnidrop-multiwarehouse-sor",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "dev:gateway": "npm run start:dev -w apps/api-gateway",
    "dev:core": "npm run start:dev -w apps/core-service",
    "dev:flash-sale": "npm run start:dev -w apps/flash-sale-service",
    "dev:order": "npm run start:dev -w apps/order-routing-service",
    "dev:web": "npm run dev -w apps/web-app",
    "test:load": "node scripts/load_test.js",
    "test:integrity": "node scripts/verify_integrity.js",
    "test:all": "node tests/run_all_tests.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@nestjs/microservices": "^11.1.28",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2"
  }
}
